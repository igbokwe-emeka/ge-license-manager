# Google Cloud Project
GCP_PROJECT_ID=your-project-id
# Optional: Comma-separated list of GCP Project IDs where the Gemini Enterprise subscriptions (Discovery Engine User Store) are located.
# If not set, GCP_PROJECT_ID is used.
SUBSCRIPTION_IDS=your-subscription-project-id,another-project-id
GCP_LOCATION=us-central1
API_LOCATION=us

# Log Analytics
LOG_BUCKET=_Default
LOG_VIEW=_AllLogs
# Set LOG_DATASET if using a linked BigQuery dataset for Log Analytics
LOG_DATASET=logging_analytics
INACTIVITY_THRESHOLD_DAYS=45

# Google Workspace
# WORKSPACE_DOMAIN=your-domain.com
# WORKSPACE_ADMIN_EMAIL=admin@your-domain.com
# Service account must have domain-wide delegation with scopes:
#   https://www.googleapis.com/auth/admin.directory.user
#   https://www.googleapis.com/auth/admin.directory.user.readonly

# Notification settings
# NOTIFICATION_SENDER_EMAIL=no-reply@your-domain.com
# Comma-separated list of org admin emails to notify
# ORG_ADMIN_EMAILS=admin1@your-domain.com,admin2@your-domain.com

# Agent Engine
AGENT_ENGINE_DISPLAY_NAME=ge-user-level-analytics-agent
STAGING_BUCKET=gs://your-staging-bucket

# Daily audit report — GCS destination
# Reports are written to: gs://AUDIT_BUCKET/YYYY/MM/DD/HH-MM-SS/usage_audit.csv
AUDIT_BUCKET=gs://your-audit-reports-bucket

# Gemini Enterprise App
APP_LOCATION= <Gemini Enterprise App location>
# Engine ID for the Gemini Enterprise / Discovery Engine app (used by Sessions API for query text)
GE_ENGINE_ID=your-engine-id

# Cloud Scheduler (daily agent run)
# Defaults to GCP_LOCATION if not set. Must be a region where Cloud Scheduler is available.
SCHEDULER_LOCATION=us-central1
# Service account email used by Cloud Scheduler to authenticate against the Vertex AI endpoint.
# Must have roles/aiplatform.user on the project.
SCHEDULER_SERVICE_ACCOUNT=your-scheduler-sa@your-project.iam.gserviceaccount.com